{
  "name": "@soulpass/passkey-sdk",
  "version": "0.1.0",
  "description": "Browser-native Solana wallet powered by WebAuthn Passkeys",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./solana-adapter": {
      "types": "./dist/adapters/solana.d.ts",
      "import": "./dist/adapters/solana.js",
      "require": "./dist/adapters/solana.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.90.0"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/web3.js": "^1.98.0",
    "jsdom": "^29.0.2",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
